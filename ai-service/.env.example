# Railway が自動設定するポート番号（ローカル開発時は手動で設定）
PORT=8000

# アプリケーション環境（development / production）
APP_ENV=development

# アプリケーションタイトル
APP_TITLE=AI Factcheck Enterprise - AI Service

# LangSmith トレーシング（オプション）
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=ai-factcheck-enterprise
LANGCHAIN_TRACING_V2=true

# OpenAI API
OPENAI_API_KEY=your-openai-api-key

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key
